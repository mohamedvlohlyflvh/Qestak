# ===== Netlify Dashboard → Site Settings → Environment Variables =====
# انسخ الملف إلى .env.local عشان تشغيل local، وحط القيم في Netlify Dashboard

# --- Database (Neon / PostgreSQL) ---
DATABASE_URL=""
DIRECT_URL=""

# --- NextAuth ---
AUTH_SECRET=""
AUTH_URL="https://your-site.netlify.app"

# --- Google OAuth ---
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Stripe Price IDs (من Stripe Dashboard → Products) ---
STRIPE_BASIC_MONTH_PRICE_ID=""
STRIPE_BASIC_YEAR_PRICE_ID=""
STRIPE_PRO_MONTH_PRICE_ID=""
STRIPE_PRO_YEAR_PRICE_ID=""
STRIPE_UNLIMITED_MONTH_PRICE_ID=""
STRIPE_UNLIMITED_YEAR_PRICE_ID=""

# --- Cron ---
CRON_SECRET=""
